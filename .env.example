# =============================================================================
# Aruba ClearPass MCP Server — Environment Configuration
# =============================================================================
# Copy this file to ".env" and fill in your values.
# NEVER commit your real .env file to version control.
# =============================================================================

# --- Required --------------------------------------------------------------- #

# Fully-qualified URL of your ClearPass Policy Manager instance.
# Do NOT include a trailing slash.
CLEARPASS_HOST=https://clearpass.yourdomain.com

# OAuth2 API client credentials.
# Create these in ClearPass UI: Administration → API Services → API Clients
# Grant type: client_credentials
CLEARPASS_CLIENT_ID=your_client_id
CLEARPASS_CLIENT_SECRET=your_client_secret

# --- Optional (with safe defaults) ----------------------------------------- #

# Set to "false" only for development/lab environments with self-signed certs.
# NEVER disable in production — MITM risk.
CLEARPASS_VERIFY_SSL=true

# When "true", all write operations (POST/PATCH/PUT/DELETE) are blocked.
# Recommended for read-only monitoring integrations.
CLEARPASS_READ_ONLY=false

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
CLEARPASS_LOG_LEVEL=INFO

# Absolute path to write structured JSON audit logs.
# If unset, audit events are only written to stdout.
# CLEARPASS_AUDIT_LOG_PATH=/var/log/clearpass-mcp/audit.jsonl

# Maximum number of pages to follow when paginating list endpoints.
# Protects against runaway pagination on large datasets.
CLEARPASS_MAX_PAGES=20
